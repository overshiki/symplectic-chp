# phase-gate: H 0; S 0; S 0 = H·Z|0⟩ = |−⟩
# Z measurement is random
deterministic: false
cases:
  - probability: 0.5
    measurement_outcomes: [+1]
    post_measurement_tableau:
      stabilizers: ["+Z"]
      destabilizers: ["-X"]
  - probability: 0.5
    measurement_outcomes: [-1]
    post_measurement_tableau:
      stabilizers: ["-Z"]
      destabilizers: ["-X"]
pre_measurement_tableau:
  stabilizers: ["-X"]
  destabilizers: ["+Z"]
